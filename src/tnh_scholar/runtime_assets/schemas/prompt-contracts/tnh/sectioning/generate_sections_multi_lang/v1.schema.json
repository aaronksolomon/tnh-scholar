{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TNH Generate Sections Multi-Language Output",
  "description": "Logical multi-language sectioning output with source-language titles, English titles, summaries, and inclusive line ranges.",
  "type": "object",
  "required": [
    "sections"
  ],
  "anyOf": [
    {
      "required": [
        "summary"
      ]
    },
    {
      "required": [
        "document_summary"
      ]
    },
    {
      "required": [
        "talk_summary"
      ]
    }
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "document_summary": {
      "type": "string"
    },
    "talk_summary": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "summary",
          "start_line",
          "end_line",
          "title_en"
        ],
        "anyOf": [
          {
            "required": [
              "title"
            ]
          },
          {
            "required": [
              "title_orig"
            ]
          },
          {
            "required": [
              "title_vi"
            ]
          }
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "title_orig": {
            "type": "string"
          },
          "title_vi": {
            "type": "string"
          },
          "title_en": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
